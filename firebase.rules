rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() && request.auth.token.email == 'owner@lovinasshop.com';
    }

    function isAdmin() {
      return isOwner() || (isSignedIn() && request.auth.token.email != null);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.token.email == resource.data.customer.email);
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /messages/{messageId} {
      allow read, write: if isOwner();
    }

    match /adminUsers/{userId} {
      allow read, write: if isOwner();
    }
  }
}